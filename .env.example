AQT_HEALTH_ENV=local
AQT_HEALTH_BOOTSTRAP_API_KEY=replace-with-a-long-random-local-key
AQT_HEALTH_BOOTSTRAP_CLIENT_NAME=local-admin
AQT_HEALTH_JDBC_URL=jdbc:postgresql://localhost:5432/aqt_health
AQT_HEALTH_DB_USER=aqt_health
AQT_HEALTH_DB_PASSWORD=aqt_health
AQT_HEALTH_DB_MAX_POOL_SIZE=10
AQT_HEALTH_GOOGLE_CLIENT_ID=replace-with-google-oauth-client-id
AQT_HEALTH_GOOGLE_CLIENT_SECRET=replace-with-google-oauth-client-secret
AQT_HEALTH_GOOGLE_REDIRECT_URI=http://localhost:8080/api/v2/providers/google-health/oauth/callback
AQT_HEALTH_GOOGLE_TOKEN_ENCRYPTION_KEY=replace-with-32-byte-minimum-secret
AQT_HEALTH_GOOGLE_API_BASE_URL=https://health.googleapis.com
AQT_HEALTH_GOOGLE_OAUTH_TOKEN_URL=https://oauth2.googleapis.com/token
AQT_HEALTH_GOOGLE_OAUTH_AUTH_URL=https://accounts.google.com/o/oauth2/v2/auth
AQT_HEALTH_WITHINGS_CLIENT_ID=replace-with-withings-client-id
AQT_HEALTH_WITHINGS_CLIENT_SECRET=replace-with-withings-client-secret
AQT_HEALTH_WITHINGS_REDIRECT_URI=http://localhost:8080/api/v2/providers/withings/oauth/callback
AQT_HEALTH_WITHINGS_TOKEN_ENCRYPTION_KEY=replace-with-32-byte-minimum-secret
AQT_HEALTH_WITHINGS_API_BASE_URL=https://wbsapi.withings.net
AQT_HEALTH_WITHINGS_OAUTH_TOKEN_URL=https://wbsapi.withings.net/v2/oauth2
AQT_HEALTH_WITHINGS_OAUTH_AUTH_URL=https://account.withings.com/oauth2_user/authorize2
AQT_HEALTH_LOG_FORMAT=text
AQT_HEALTH_LOG_FILE=build/logs/aqt-health.jsonl
AQT_HEALTH_LOG_FILE_ROLLOVER=build/logs/aqt-health.%d{yyyy-MM-dd}.%i.jsonl.gz
OPENOBSERVE_LOG_URL=
OPENOBSERVE_AUTHORIZATION=Basic XXX
PORT=8080

# Production deployments must set AQT_HEALTH_ENV=production and replace all
# local defaults/placeholders with real secret values and public HTTPS origins:
# AQT_HEALTH_ENV=production
# AQT_HEALTH_BOOTSTRAP_API_KEY=replace-with-32-byte-minimum-production-api-key
# AQT_HEALTH_BOOTSTRAP_CLIENT_NAME=production-admin
# AQT_HEALTH_JDBC_URL=jdbc:postgresql://db.example.internal:5432/aqt_health
# AQT_HEALTH_DB_USER=aqt_health_app
# AQT_HEALTH_DB_PASSWORD=replace-with-strong-production-db-password
# AQT_HEALTH_GOOGLE_REDIRECT_URI=https://api.example.com/api/v2/providers/google-health/oauth/callback
# AQT_HEALTH_WITHINGS_REDIRECT_URI=https://api.example.com/api/v2/providers/withings/oauth/callback
# AQT_HEALTH_GOOGLE_TOKEN_ENCRYPTION_KEY=replace-with-32-byte-minimum-production-secret
# AQT_HEALTH_WITHINGS_TOKEN_ENCRYPTION_KEY=replace-with-32-byte-minimum-production-secret
# AQT_HEALTH_CORS_ORIGINS=https://app.example.com
